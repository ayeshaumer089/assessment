# This is a non-dotfile env template (so editors/tools won't block it).
# Copy/paste the contents into `Backend/.env` on your machine and replace placeholders.

PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=postmessage

FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_SECRET=
PASSWORD_RESET_TOKEN_EXPIRES_IN=15m

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="NexusAI <yourgmail@gmail.com>"
